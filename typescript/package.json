{
  "name": "xtalent-graph",
  "version": "0.1.0",
  "description": "TypeScript SDK for the xTalent Graph open talent protocol.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "example": "tsx example.ts",
    "test": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "talent",
    "cv",
    "ipfs",
    "agents",
    "llm",
    "vector-search"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/OWNER/xtalent-graph.git"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
